# Copy to .env.local (local) or set in Vercel → Settings → Environment Variables.

# Required for API routes that use the DB (build + runtime)
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Neon Auth — required at runtime for sign-in/session; cookie secret must be ≥32 characters
# Generate: openssl rand -base64 32
NEON_AUTH_BASE_URL=https://your-neon-auth-host.example
NEON_AUTH_COOKIE_SECRET=replace-with-32-plus-char-secret

# Optional — browser → API (see web/lib/mus/public.ts)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8002
