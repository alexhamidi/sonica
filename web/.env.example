# Copy to .env.local (local) or set in Vercel → Settings → Environment Variables.

# Required — database (Neon pooled URL)
POSTGRES_URL=

# Required — Neon Auth (Console → Auth): base URL for the auth API
NEON_AUTH_BASE_URL=

# Required — session cookie signing; must be ≥32 characters
# Generate: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# Optional — browser → Python API (see web/lib/mus/public.ts)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8002
