# Copy to py/.env and fill in (never commit .env).

# Required by server.py (Pydantic Settings)
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
S3_BUCKET=your-bucket-name

# Optional — default us-east-1 if omitted
# AWS_DEFAULT_REGION=us-east-1

# Optional — if set, public URLs use this instead of virtual-hosted S3 URL
# CDN_BASE=https://cdn.example.com

# Required by ingest.py (embeddings / search). Same DB as above works.
# POSTGRES_URL is already set above.

# Optional — Vertex AI / Gemini (defaults in ingest.py if unset)
# GEMINI_PROJECT_ID=your-gcp-project-id
# GEMINI_LOCATION=us-central1
# Optional — path to GCP service account JSON (Vertex AI User). Or use gcloud auth application-default login.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa.json

# If you use AWS APIs from the CLI or other tools (not read by server.py Settings),
# set standard AWS env vars locally only:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
